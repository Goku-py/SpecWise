DATABASE_URL=postgresql://user:password@localhost:5432/specwise

# Unsplash API — used to fetch laptop product images
# Get your free Access Key at https://unsplash.com/developers
# 1. Sign up / log in
# 2. Click "New Application"
# 3. Name it "SpecWise" (or whatever you like)
# 4. Copy the "Access Key" (not Secret Key)
UNSPLASH_ACCESS_KEY=

# Resend API — used to send result emails to quiz users
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=

# Admin API key — protects PATCH /api/laptops/[id] and /api/laptops
# Generate a strong random token and send it as Authorization: Bearer <token>
ADMIN_API_KEY=

# TechSpecs API — fetches full laptop specs (300+ fields)
# Get your API ID + Key at https://techspecs.io/dashboard (free tier available)
# Used by: scripts/fetch-laptops.ts
TECHSPECS_API_ID=
TECHSPECS_API_KEY=

# PricesAPI — fetches live multi-retailer pricing globally
# Get your API key at https://pricesapi.io/signup (free: 1,000 calls/month)
# Used by: scripts/fetch-laptops.ts
PRICESAPI_API_KEY=

# Postgres connection pool tuning
POSTGRES_POOL_MAX=5
POSTGRES_POOL_IDLE_TIMEOUT_MS=120000
POSTGRES_POOL_CONNECTION_TIMEOUT_MS=5000

# Public app URL — used by the seed script to invalidate the catalog cache
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Catalog cache TTL in seconds
CATALOG_CACHE_TTL_SECONDS=3600
